{
  "name": "NeonGlow",
  "description": "霓虹发光效果叠加层，可叠加到歌词或标题上，支持脉冲动画",
  "params": {
    "glowColor": {
      "type": "string",
      "default": "#ff00ff",
      "description": "发光颜色"
    },
    "glowIntensity": {
      "type": "number",
      "default": 0.8,
      "min": 0,
      "max": 1,
      "description": "发光强度"
    },
    "glowRadius": {
      "type": "number",
      "default": 40,
      "description": "发光半径（像素）"
    },
    "pulseSpeed": {
      "type": "number",
      "default": 0,
      "min": 0,
      "max": 2,
      "description": "脉冲速度，0 为不脉冲"
    }
  }
}