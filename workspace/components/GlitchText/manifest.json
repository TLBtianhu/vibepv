{
  "name": "GlitchText",
  "description": "故障风字幕覆盖层，提供赛博朋克风格的文字撕裂、RGB 偏移和随机闪烁效果",
  "requires": { "data": ["lyrics.words", "bpm"] },
  "params": {
    "intensity": {
      "type": "number",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "description": "故障强度（0~1的小数）"
    },
    "color": {
      "type": "string",
      "default": "#ff00ff",
      "description": "故障色条颜色（十六进制颜色值）"
    }
  }
}