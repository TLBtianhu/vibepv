{
  "name": "KaraokeHighlight",
  "description": "逐字卡拉OK高亮效果，根据歌词时间戳高亮当前正在唱的字",
  "requires": { "data": ["lyrics.words"] },
  "params": {
    "highlightColor": {
      "type": "string",
      "default": "#ffff00",
      "description": "高亮颜色"
    },
    "glowColor": {
      "type": "string",
      "description": "发光颜色（可选）"
    }
  }
}